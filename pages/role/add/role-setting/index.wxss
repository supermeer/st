.role-setting-page {
  position: relative;
  height: 100vh;
  overflow: hidden;
  background: #000;
  color: #fff;
  overflow: hidden;
}

.page-body {
  width: 100%;
  padding-left: 24rpx;
  padding-right: 24rpx;
  box-sizing: border-box;
  overflow-y: scroll;
}

.header-block {
  padding: 20rpx 0 16rpx;
  width: 100%;
}

.header-title {
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 700;
  letter-spacing: 0.2rpx;
}

.required-star {
  color: #ff4d4f;
  margin-right: 8rpx;
}

.header-desc {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.62);
}

.editor-card {
  width: 100%;
  height: calc(100% - 60px);
  margin-bottom: 24rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.1);
  overflow: hidden;
}

.editor-textarea {
  width: 100%;
  height: 100%;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  font-weight: 400;
  line-height: 1.5;
  color: #fff;
}

.editor-placeholder {
  color: rgba(255, 255, 255, 0.38);
  font-size: 29rpx;
  line-height: 1.7;
}

.shortcut-panel {
  width: 100%;
  padding: 18rpx 0;
  box-sizing: border-box;
  overflow: hidden;
}

.shortcut-row {
  display: flex;
  align-items: flex-start;
}

.quick-row {
  margin-top: 10rpx;
}

.shortcut-label {
  width: 68rpx;
  padding-top: 8rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.68);
}

.shortcut-scroll {
  flex: 1;
  min-width: 0;
}

.shortcut-list {
  width: 100%;
}

.inline-list {
  padding-right: 18rpx;
}

.shortcut-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 92rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: #4c4c4c;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.submit-footer {
  width: 100%;
  z-index: 100;
  padding: 16rpx 24rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.88) 0%, rgba(0, 0, 0, 0) 100%);
  box-sizing: border-box;
}

.submit-btn {
  height: 88rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(90deg, #9418db 0%, #4b4dff 100%);
}
