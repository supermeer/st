<view class="role-setting-page">
  <view class="nav-shell">
    <custom-nav id="roleSettingNav" title="" showBack="{{true}}" showHome="{{false}}" transparent="{{true}}" />
  </view>

  <view class="page-body" style="top: {{pageInfo.navHeight}}px; bottom: {{pageBodyBottom}};">
    <view class="header-block">
      <view class="header-title">
        <text class="required-star">*</text>
        智能体设定（决定了智能体回复效果）
      </view>
      <view class="header-desc">决定智能体的对话效果，且仅创作者可见，不会对外展示。</view>
    </view>

    <view class="editor-card" style="{{editorCardStyle}}">
      <textarea
        class="editor-textarea"
        placeholder="{{placeholder}}"
        placeholder-class="editor-placeholder"
        value="{{value}}"
        maxlength="10000"
        show-confirm-bar="false"
        cursor-spacing="24"
        adjust-position="false"
        hold-keyboard="true"
        focus
        cursor="{{cursorPosition}}"
        bindinput="onInput"
        bindfocus="onFocus"
        bindblur="onBlur"
        bindkeyboardheightchange="onKeyboardHeightChange"
      />
    </view>
  </view>

  <view wx:if="{{isKeyboardVisible}}" class="shortcut-panel" style="bottom: {{shortcutBottom}}; height: {{shortcutPanelHeight}};">
    <view class="shortcut-row">
      <view class="shortcut-label">常用</view>
      <scroll-view class="shortcut-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="shortcut-list inline-list">
          <view
            wx:for="{{commonTemplates}}"
            wx:key="name"
            class="shortcut-chip"
            data-value="{{item}}"
            bindtap="onInsertTemplate"
          >
            {{item.name}}
          </view>
        </view>
      </scroll-view>
    </view>
    <view class="shortcut-row quick-row">
      <view class="shortcut-label">快捷</view>
      <scroll-view class="shortcut-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="shortcut-list inline-list">
          <view
            wx:for="{{quickTemplates}}"
            wx:key="name"
            class="shortcut-chip"
            data-value="{{item}}"
            bindtap="onInsertTemplate"
          >
            {{item.name}}
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="submit-footer" style="padding-bottom: {{pageInfo.safeAreaBottom}}px;">
    <view class="submit-btn" bindtap="onSubmit">保存</view>
  </view>
</view>

<tip-dialog id="tip-dialog" />
