.voice-page {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: 0;
  object-fit: cover;
}

.page-bg-mask {
  background: linear-gradient(180deg, rgba(8, 7, 17, 0.12) 0%, rgba(10, 9, 18, 0.45) 24%, rgba(10, 9, 18, 0.78) 62%, rgba(10, 9, 18, 0.92) 100%);
}

.tab-bar {
  position: relative;
  z-index: 10;
  margin: 0 32rpx;
  padding: 8rpx;
  display: flex;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.16);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.tab-item {
  flex: 1;
  height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%);
  box-shadow: 0 12rpx 28rpx rgba(109, 40, 217, 0.28);
}

.tab-text {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.82);
}

.tab-item.active .tab-text {
  color: #fff;
}

.filter-panel {
  position: relative;
  z-index: 10;
  padding: 28rpx 32rpx 18rpx;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
  height: 68rpx;
}

.filter-row {
  display: inline-flex;
  align-items: center;
  min-width: 100%;
  gap: 18rpx;
}

.filter-chip {
  flex-shrink: 0;
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.82);
  background: rgba(255, 255, 255, 0.1);
}
.tag-chip {
  flex-shrink: 0;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.82);
  margin-right: 14rpx;
}

.filter-chip.active {
  color: #fff;
  background: rgba(139, 92, 246, 0.28);
}
.tag-chip.active {
  color: var(--theme-color-purple);
  border-bottom: 2px solid var(--theme-color-purple);
}

.scroll-content {
  position: relative;
  z-index: 1;
  flex: 1;
  width: 100%;
}

.voice-list {
  padding: 0 32rpx;
}

.voice-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  margin-bottom: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.voice-item-selected {
  border-color: var(--theme-color-purple);
  box-shadow: 0 0 0 2rpx rgba(248, 214, 109, 0.18) inset;
}

.voice-item-main {
  flex: 1;
  min-width: 0;
}

.voice-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.voice-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.voice-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.voice-selected-mark {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #fff;
  background: var(--theme-color-purple);
}

.voice-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.voice-play,
.voice-favorite {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
}

.voice-play {
  min-width: 88rpx;
  width: auto;
  padding: 0 20rpx;
  border-radius: 999rpx;
}

.voice-play.active {
  background: rgba(139, 92, 246, 0.16);
}

.voice-play-text {
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.88);
}

.voice-play.active .voice-play-text {
  color: var(--theme-color-purple);
}

.voice-favorite.active {
  background: rgba(248, 214, 109, 0.16);
}

.voice-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.voice-tag {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
}

.empty-state {
  margin-top: 30rpx;
  padding: 120rpx 36rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-image {
  width: 220rpx;
  height: 220rpx;
  margin-bottom: 24rpx;
  opacity: 0.92;
  border-radius: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.empty-sub {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.66);
  text-align: center;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
}

.action-btn {
  height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.outline-btn {
  width: 212rpx;
  /* border: 2rpx solid rgba(255, 255, 255, 0.32);
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx); */
}

.outline-btn .btn-text {
  color: var(--theme-color-purple);
}

.primary-btn {
  flex: 1;
  background: linear-gradient(135deg, #8b5cf6 0%, #4f46e5 100%);
  box-shadow: 0 12rpx 30rpx rgba(99, 102, 241, 0.36);
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}
