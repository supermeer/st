<view class="voice-page">
  <image class="page-bg" src="{{showBG ? currentBg : backgroundPlaceholder}}" mode="aspectFill"></image>
  <view class="page-bg page-bg-mask"></view>

  <custom-nav title="" id="roleVoiceNav" showBack="{{true}}" showHome="{{false}}" transparent="{{true}}" />

  <view class="tab-bar">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" data-index="0" bind:tap="onTabChange">
      <text class="tab-text">全部声音</text>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" data-index="1" bind:tap="onTabChange">
      <text class="tab-text">我的收藏</text>
    </view>
  </view>

  <view class="filter-panel">
    <scroll-view class="filter-scroll" scroll-x show-scrollbar="{{false}}">
      <view class="filter-row">
        <view
          wx:for="{{genderTabs}}"
          wx:key="*this"
          class="filter-chip {{activeGender === item ? 'active' : ''}}"
          data-gender="{{item}}"
          bind:tap="onGenderChange"
        >
          {{item}}
        </view>
      </view>
    </scroll-view>

    <scroll-view class="filter-scroll" scroll-x show-scrollbar="{{false}}">
      <view class="filter-row compact-row">
        <view
          wx:for="{{availableTags}}"
          wx:key="*this"
          class="tag-chip {{activeTag === item ? 'active' : ''}}"
          data-tag="{{item}}"
          bind:tap="onTagChange"
        >
          {{'#' + item}}
        </view>
      </view>
    </scroll-view>
  </view>

  <scroll-view
    class="scroll-content"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    scroll-top="{{scrollTop}}"
    style="height: calc(100vh - {{ pageInfo.navHeight }}px - 300rpx);"
  >
    <view class="voice-list" style="padding-bottom: calc({{ pageInfo.safeAreaBottom }}px + 160rpx);">
      <view wx:if="{{!visibleVoiceList.length}}" class="empty-state blur-glass">
        <image class="empty-image" src="{{backgroundPlaceholder}}" mode="aspectFit"></image>
        <text class="empty-text">{{emptyTip}}</text>
        <text class="empty-sub">tips：长按声音卡片，可收藏自己喜欢的声音哦~</text>
      </view>

      <view
        wx:for="{{visibleVoiceList}}"
        wx:key="id"
        class="voice-item blur-glass {{item.selected ? 'voice-item-selected' : ''}}"
        data-id="{{item.id}}"
        bind:tap="onSelectVoice"
        bind:longpress="onToggleFavorite"
      >
        <view class="voice-item-main">
          <view class="voice-header">
            <view class="voice-title-wrap">
              <text class="voice-name">{{item.name}}</text>
              <text wx:if="{{item.isCurrent}}" class="voice-selected-mark">当前声音</text>
            </view>
            <view class="voice-actions">
              <view class="voice-play {{item.isPlaying ? 'active' : ''}}" data-id="{{item.id}}" catch:tap="onPlayVoice">
                <text class="voice-play-text">{{item.isPlaying ? '暂停' : '试听'}}</text>
              </view>
              <view class="voice-favorite {{item.favorite ? 'active' : ''}}" data-id="{{item.id}}" catch:tap="onToggleFavorite">
                <t-icon name="star" size="34rpx" color="{{item.favorite ? '#8b5cf6' : 'rgba(255,255,255,0.72)'}}" />
              </view>
            </view>
          </view>
          <view class="voice-tags">
            <text wx:for="{{item.tags}}" wx:key="*this" class="voice-tag">#{{item}}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-actions" style="padding-bottom: {{ pageInfo.safeAreaBottom }}px;">
    <view class="action-btn outline-btn" bind:tap="onResetSettings">
      <text class="btn-text">恢复默认设置</text>
    </view>
    <view class="action-btn primary-btn" bind:tap="onSaveSettings">
      <text class="btn-text">保存设置</text>
    </view>
  </view>
</view>

<tip-dialog id="tip-dialog" />