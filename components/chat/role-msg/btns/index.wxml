<view class="btns-container {{disabled ? 'btns-disabled' : ''}}">
  <!-- <image class="btn-image" src="/static/chat/bf.svg" data-action="play" bind:tap="onBtnClick" /> -->
  <view wx:if="{{isLatest}}" class="btn-container" data-action="retry" catchtap="onBtnClick">
    <image class="btn-image" src="/static/chat/cs.svg" />
    <text class="btn-text">重说</text>
  </view>
  <view wx:if="{{isLatest}}" class="btn-container" data-action="continue" catchtap="onBtnClick" >
    <image class="btn-image" src="/static/chat/jx.svg" />
    <text class="btn-text">继续</text>
  </view>

  <view wx:if="{{roleDetail.userVoiceId || roleDetail.voiceId}}" class="btn-container" data-action="play" catchtap="onBtnClick" >
    <van-icon wx:if="{{!isPlaying}}" class="btn-image" color="#fff" name="play-circle-o" />
    <van-icon wx:else class="btn-image" color="#fff" name="pause-circle-o" />
    <text class="btn-text">播放</text>
  </view>

  <view wx:if="{{showTip && isLatest}}" class="bottom-line">
    <text class="btm-text">如果不知道回什么，可以点击</text>
    <image class="btm-image" src="/static/chat/linggan.png" />
    <text class="btm-close-text" catchtap="closeTip">不再提示</text>
  </view>
  
</view>
